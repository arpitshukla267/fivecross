{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/", "dest": "/api/index.php" },
    { "src": "/(.*).php", "dest": "/api/$1.php" },
    { "src": "/(.*)", "dest": "/api/$1.php", "check": true }
  ]
}
