{
  "version": 2,
  "builds": [
    { "src": "*.php", "use": "vercel-php@0.7.2" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "js/**", "use": "@vercel/static" },
    { "src": "image/**", "use": "@vercel/static" },
    { "src": "font/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/(.*).php", "dest": "/$1.php" },
    { "src": "/(.*)", "dest": "/$1.php", "check": true },
    { "src": "/", "dest": "/index.php" }
  ]
}
